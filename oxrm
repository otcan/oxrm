#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$repo_root"

instance="${OXRM_INSTANCE:-${CRM_INSTANCE:-demo}}"

usage() {
  cat <<'EOF'
Usage: ./oxrm [--instance name] <command> [args]

Common commands:
  init [name] [--template t] [--ports auto]
                      Guided first run: blank, job-search, or outreach
  codex-demo [--reset] [--check]
                      Start, seed, and smoke-test the local Codex demo
  setup [--demo s]   Create the local env file; optionally install one demo scenario
  start              Start Docker containers
  stop               Stop Docker containers
  reset              Stop containers and delete local Docker data for the instance
  restart            Restart Docker containers
  status             Show containers
  urls               Print local URLs
  ports              Print local URLs and ports
  ports repair       Reassign web/API/MCP ports when they are blocked
  doctor [--codex]   Check Docker, ports, instance config, and optionally Codex
  repair             Repair ports, remove orphans, migrate, seed, restart, smoke
  ready              Run migrate and baseline seed
  upgrade            Backup, migrate, seed, restart, and smoke-test the instance
  demo [scenario]    Seed public-safe demo data: job-search, linkedin-outreach, or codex-demo
  test               Run DB smoke, health, and CLI smoke
  health             Run instance health check
  version            Print local product version without requiring an instance
  cli [args]         Run the oXRM CLI inside Docker
  tools              List MCP tools through the Dockerized CLI
  logs [service]     Follow logs

Instance commands:
  new <name>         Create a new instance example from demo
  instance [args]    Pass through to scripts/oxrm-instance

Options:
  -i, --instance     Instance name, default: demo

Compatibility:
  ./ocrm still delegates to ./oxrm, but it is deprecated.

Examples:
  ./oxrm init
  ./oxrm init personal --template job-search --ports auto
  ./oxrm init client-a --template blank
  ./oxrm init --template job-search
  ./oxrm init --template blank
  ./oxrm codex-demo
  ./oxrm codex-demo --reset --check
  ./oxrm setup --demo none
  ./oxrm start
  ./oxrm repair
  ./oxrm ready
  ./oxrm seed job-search
  ./oxrm seed outreach --reset-demo
  ./oxrm test
  ./oxrm version
  ./oxrm cli mcp:tools
  ./oxrm -i client-a start
EOF
}

run_instance() {
  scripts/oxrm-instance "$instance" "$@"
}

print_version() {
  node - <<'NODE'
const pkg = require("./package.json");

console.log(JSON.stringify({
  product: {
    name: "oXRM",
    slug: "oxrm",
    version: pkg.version
  },
  note: "This command reads local package metadata and does not require an initialized instance."
}, null, 2));
NODE
}

ensure_instance_env() {
  env_file="instances/${instance}.local.env"
  example_env_file="instances/${instance}.env.example"
  if [[ ! -f "$env_file" && -f "$example_env_file" ]]; then
    OXRM_INIT_PORTS=auto run_instance init
  elif [[ ! -f "$env_file" && -f "instances/demo.env.example" ]]; then
    OXRM_INIT_PORTS=auto run_instance init
  fi
}

valid_demo_scenario() {
  case "$1" in
    none|job-search|linkedin-outreach|codex-demo)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

parse_demo_option() {
  demo_scenario="__unset"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --demo)
        if [[ $# -lt 2 ]]; then
          echo "Missing scenario after --demo" >&2
          exit 2
        fi
        demo_scenario="$2"
        shift 2
        ;;
      --demo=*)
        demo_scenario="${1#*=}"
        shift
        ;;
      *)
        echo "Unknown option for setup: $1" >&2
        exit 2
        ;;
    esac
  done
}

parse_init_option() {
  init_template="__unset"
  init_ports="auto"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --template|--profile)
        if [[ $# -lt 2 ]]; then
          echo "Missing template after $1" >&2
          exit 2
        fi
        init_template="$2"
        shift 2
        ;;
      --template=*|--profile=*)
        init_template="${1#*=}"
        shift
        ;;
      --ports)
        if [[ $# -lt 2 ]]; then
          echo "Missing mode after --ports" >&2
          exit 2
        fi
        init_ports="$2"
        shift 2
        ;;
      --ports=*)
        init_ports="${1#*=}"
        shift
        ;;
      --demo)
        if [[ $# -lt 2 ]]; then
          echo "Missing scenario after --demo" >&2
          exit 2
        fi
        case "$2" in
          none) init_template="blank" ;;
          job-search) init_template="job-search" ;;
          linkedin-outreach) init_template="outreach" ;;
          *) init_template="$2" ;;
        esac
        shift 2
        ;;
      --demo=*)
        case "${1#*=}" in
          none) init_template="blank" ;;
          job-search) init_template="job-search" ;;
          linkedin-outreach) init_template="outreach" ;;
          *) init_template="${1#*=}" ;;
        esac
        shift
        ;;
      *)
        echo "Unknown option for init: $1" >&2
        exit 2
        ;;
    esac
  done
}

choose_setup_demo() {
  if [[ "$demo_scenario" != "__unset" ]]; then
    return
  fi
  demo_scenario=none
  if [[ -t 0 ]]; then
    printf 'Demo data? [none/job-search/linkedin-outreach] (none): ' >&2
    read -r answer || answer=""
    if [[ -n "$answer" ]]; then
      demo_scenario="$answer"
    fi
  fi
}

normalize_init_template() {
  case "$init_template" in
    ""|"__unset")
      init_template="blank"
      ;;
    blank|none|no-demo)
      init_template="blank"
      ;;
    job|jobs|job-search|job_search)
      init_template="job-search"
      ;;
    outreach|crm|linkedin|linkedin-outreach|linkedin_outreach)
      init_template="outreach"
      ;;
    *)
      echo "Unknown init template: $init_template" >&2
      echo "Use blank, job-search, or outreach." >&2
      exit 2
      ;;
  esac
}

normalize_demo_scenario() {
  case "${1:-none}" in
    none|blank|no-demo)
      echo "none"
      ;;
    job|jobs|job-search|job_search)
      echo "job-search"
      ;;
    outreach|crm|linkedin|linkedin-outreach|linkedin_outreach)
      echo "linkedin-outreach"
      ;;
    codex|codex-demo|codex_demo)
      echo "codex-demo"
      ;;
    *)
      echo "$1"
      ;;
  esac
}

choose_init_template() {
  if [[ "$init_template" != "__unset" ]]; then
    normalize_init_template
    return
  fi
  init_template="blank"
  if [[ -t 0 ]]; then
    cat >&2 <<'EOF'
Choose an oXRM workspace:
  1) Job search: applications, CVs, cover letters, fits, follow-ups
  2) Outreach / CRM: leads, people, companies, tasks, relationship history
  3) Blank local workspace: structure only, no synthetic demo records
EOF
    printf 'Selection [3]: ' >&2
    read -r answer || answer=""
    case "$answer" in
      1|job|jobs|job-search) init_template="job-search" ;;
      2|outreach|crm|linkedin|linkedin-outreach) init_template="outreach" ;;
      ""|3|blank|none) init_template="blank" ;;
      *) init_template="$answer" ;;
    esac
  fi
  normalize_init_template
}

init_demo_scenario() {
  case "$init_template" in
    job-search) echo "job-search" ;;
    outreach) echo "linkedin-outreach" ;;
    blank) echo "none" ;;
  esac
}

print_init_next_steps() {
  scenario="$(init_demo_scenario)"
  instance_flag=""
  if [[ "$instance" != "demo" ]]; then
    instance_flag="-i ${instance} "
  fi
  cat <<EOF

oXRM is initialized.

Template: ${init_template}
Demo scenario: ${scenario}

Next:
  ./oxrm ${instance_flag}urls
  open the Web URL
  go to /start

Assistant prompt:
  Ask your assistant to inspect the Start page, active playbook, sources, timers, queue, records, and draft-only suggestions. Do not send anything externally.
EOF
}

run_codex_demo() {
  bash scripts/codex-demo.sh "$@"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -i|--instance)
      if [[ $# -lt 2 ]]; then
        echo "Missing instance name after $1" >&2
        exit 2
      fi
      instance="$2"
      shift 2
      ;;
    --instance=*)
      instance="${1#*=}"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      break
      ;;
  esac
done

command="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command" in
  help)
    usage
    ;;
  init)
    if [[ $# -gt 0 && "$1" != -* ]]; then
      instance="$1"
      shift
    fi
    parse_init_option "$@"
    choose_init_template
    scenario="$(init_demo_scenario)"
    if [[ "$init_ports" == "auto" ]]; then
      OXRM_INIT_PORTS=auto run_instance init
    elif [[ "$init_ports" == "default" || "$init_ports" == "static" ]]; then
      run_instance init
    else
      echo "Unknown ports mode: $init_ports" >&2
      echo "Use --ports auto or omit it." >&2
      exit 2
    fi
    ensure_instance_env
    run_instance up
    run_instance migrate
    run_instance seed
    if [[ "$scenario" != none ]]; then
      run_instance demo-seed "$scenario"
    fi
    run_instance urls
    print_init_next_steps
    ;;
  codex-demo)
    run_codex_demo "$@"
    ;;
  setup|install)
    parse_demo_option "$@"
    choose_setup_demo
    demo_scenario="$(normalize_demo_scenario "$demo_scenario")"
    if ! valid_demo_scenario "$demo_scenario"; then
      echo "Unknown demo scenario: $demo_scenario" >&2
      echo "Use none, job-search, linkedin-outreach, or codex-demo." >&2
      exit 2
    fi
    OXRM_INIT_PORTS=auto run_instance init
    if [[ "$demo_scenario" != none ]]; then
      ensure_instance_env
      run_instance up
      run_instance migrate
      run_instance seed
      run_instance demo-seed "$demo_scenario"
      run_instance urls
    fi
    ;;
  start|up)
    ensure_instance_env
    run_instance up
    ;;
  stop|down)
    run_instance down
    ;;
  reset)
    run_instance reset
    ;;
  restart)
    run_instance down
    run_instance up
    ;;
  status|ps)
    run_instance ps
    ;;
  urls)
    ensure_instance_env
    run_instance urls
    ;;
  ports)
    ensure_instance_env
    if [[ "${1:-}" == "repair" ]]; then
      shift
      run_instance ports-repair "$@"
    else
      run_instance ports "$@"
    fi
    ;;
  doctor)
    ensure_instance_env
    run_instance doctor "$@"
    ;;
  repair)
    ensure_instance_env
    run_instance repair "$@"
    ;;
  ready|bootstrap)
    run_instance migrate
    run_instance seed
    ;;
  upgrade)
    run_instance upgrade "$@"
    ;;
  test|smoke)
    run_instance db-smoke
    run_instance health
    run_instance smoke
    ;;
  health)
    run_instance health
    ;;
  version)
    print_version
    ;;
  migrate)
    run_instance migrate
    ;;
  seed)
    scenario="none"
    if [[ $# -gt 0 && "$1" != -* ]]; then
      scenario="$1"
      shift
    fi
    scenario="$(normalize_demo_scenario "$scenario")"
    if ! valid_demo_scenario "$scenario"; then
      echo "Unknown seed scenario: $scenario" >&2
      echo "Use none, job-search, outreach, linkedin-outreach, or codex-demo." >&2
      exit 2
    fi
    run_instance seed
    if [[ "$scenario" != none || " $* " == *" --reset-demo "* ]]; then
      run_instance demo-seed "$scenario" "$@"
    fi
    ;;
  demo|demo-seed)
    scenario="$(normalize_demo_scenario "${1:-job-search}")"
    if [[ $# -gt 0 ]]; then
      shift
    fi
    if ! valid_demo_scenario "$scenario"; then
      echo "Unknown demo scenario: $scenario" >&2
      echo "Use none, job-search, linkedin-outreach, or codex-demo." >&2
      exit 2
    fi
    run_instance demo-seed "$scenario" "$@"
    ;;
  db-smoke)
    run_instance db-smoke
    ;;
  cli)
    run_instance cli "$@"
    ;;
  tools)
    run_instance cli mcp:tools
    ;;
  logs)
    run_instance logs "$@"
    ;;
  backup)
    run_instance backup
    ;;
  verify)
    run_instance verify
    ;;
  new)
    if [[ $# -lt 1 ]]; then
      echo "Usage: ./oxrm new <name>" >&2
      exit 2
    fi
    new_instance="$1"
    example_file="instances/${new_instance}.env.example"
    if [[ -e "$example_file" ]]; then
      echo "$example_file already exists."
    else
      cp instances/demo.env.example "$example_file"
      echo "Created $example_file."
    fi
    OXRM_INIT_PORTS=auto scripts/oxrm-instance "$new_instance" init
    ;;
  instance)
    if [[ $# -lt 2 ]]; then
      echo "Usage: ./oxrm instance <name> <command> [args]" >&2
      exit 2
    fi
    scripts/oxrm-instance "$@"
    ;;
  *)
    echo "Unknown command: $command" >&2
    usage
    exit 2
    ;;
esac
