#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$repo_root"

instance="${OXRM_INSTANCE:-${CRM_INSTANCE:-demo}}"

usage() {
  cat <<'EOF'
Usage: ./oxrm [--instance name] <command> [args]

Common commands:
  setup              Create the local env file for the instance
  start              Start Docker containers
  stop               Stop Docker containers
  restart            Restart Docker containers
  status             Show containers
  urls               Print local URLs
  ready              Run migrate and baseline seed
  upgrade            Backup, migrate, seed, restart, and smoke-test the instance
  demo               Seed public-safe demo data
  test               Run DB smoke, health, and CLI smoke
  health             Run instance health check
  version            Print local product version without requiring an instance
  cli [args]         Run the oXRM CLI inside Docker
  tools              List MCP tools through the Dockerized CLI
  logs [service]     Follow logs

Instance commands:
  new <name>         Create a new instance example from demo
  instance [args]    Pass through to scripts/crm-instance

Options:
  -i, --instance     Instance name, default: demo

Compatibility:
  ./ocrm still delegates to ./oxrm, but it is deprecated.

Examples:
  ./oxrm setup
  ./oxrm start
  ./oxrm ready
  ./oxrm test
  ./oxrm version
  ./oxrm cli mcp:tools
  ./oxrm -i client-a start
EOF
}

run_instance() {
  scripts/crm-instance "$instance" "$@"
}

print_version() {
  node - <<'NODE'
const pkg = require("./package.json");

console.log(JSON.stringify({
  product: {
    name: "oXRM",
    slug: "oxrm",
    version: pkg.version
  },
  note: "This command reads local package metadata and does not require an initialized instance."
}, null, 2));
NODE
}

ensure_instance_env() {
  env_file="instances/${instance}.local.env"
  example_env_file="instances/${instance}.env.example"
  if [[ ! -f "$env_file" && -f "$example_env_file" ]]; then
    run_instance init
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -i|--instance)
      if [[ $# -lt 2 ]]; then
        echo "Missing instance name after $1" >&2
        exit 2
      fi
      instance="$2"
      shift 2
      ;;
    --instance=*)
      instance="${1#*=}"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      break
      ;;
  esac
done

command="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command" in
  help)
    usage
    ;;
  setup|init|install)
    run_instance init
    ;;
  start|up)
    ensure_instance_env
    run_instance up
    ;;
  stop|down)
    run_instance down
    ;;
  restart)
    run_instance down
    run_instance up
    ;;
  status|ps)
    run_instance ps
    ;;
  urls)
    run_instance urls
    ;;
  ready|bootstrap)
    run_instance migrate
    run_instance seed
    ;;
  upgrade)
    run_instance upgrade "$@"
    ;;
  test|smoke)
    run_instance db-smoke
    run_instance health
    run_instance smoke
    ;;
  health)
    run_instance health
    ;;
  version)
    print_version
    ;;
  migrate)
    run_instance migrate
    ;;
  seed)
    run_instance seed
    ;;
  demo|demo-seed)
    run_instance demo-seed
    ;;
  db-smoke)
    run_instance db-smoke
    ;;
  cli)
    run_instance cli "$@"
    ;;
  tools)
    run_instance cli mcp:tools
    ;;
  logs)
    run_instance logs "$@"
    ;;
  backup)
    run_instance backup
    ;;
  verify)
    run_instance verify
    ;;
  new)
    if [[ $# -lt 1 ]]; then
      echo "Usage: ./oxrm new <name>" >&2
      exit 2
    fi
    new_instance="$1"
    example_file="instances/${new_instance}.env.example"
    if [[ -e "$example_file" ]]; then
      echo "$example_file already exists."
    else
      cp instances/demo.env.example "$example_file"
      echo "Created $example_file. Edit ports and names before starting it."
    fi
    scripts/crm-instance "$new_instance" init
    ;;
  instance)
    if [[ $# -lt 2 ]]; then
      echo "Usage: ./oxrm instance <name> <command> [args]" >&2
      exit 2
    fi
    scripts/crm-instance "$@"
    ;;
  *)
    echo "Unknown command: $command" >&2
    usage
    exit 2
    ;;
esac
