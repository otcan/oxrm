#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/oxrm-instance <instance> <command> [args]

Commands:
  init          Create instances/<instance>.local.env from the example
  config        Render docker compose config when Compose is available
  up            Start the instance
  down          Stop the instance
  doctor        Check Docker, ports, instance config, and optionally Codex
  ports         Print host ports used by this instance
  ports-repair  Reassign web/API/MCP ports if blocked by another process
  repair        Repair ports, remove orphans, migrate, seed, restart, smoke
  reset         Stop containers and delete local Docker data for the instance
  ps            Show containers
  logs [svc]    Follow logs
  cli [args]    Run the oXRM CLI inside the instance network
  migrate       Run Drizzle migrations
  seed          Seed initial data
  demo-seed     Seed public-safe synthetic demo data
  db-smoke      Run DB smoke check
  health        Run CLI health check inside the instance network
  smoke         Run CLI smoke check inside the instance network
  backup        Run backup worker once
  verify        Verify latest backup metadata
  urls          Print local URLs
  upgrade       Safely update one instance: backup, migrate, seed, optional demo, restart, smoke
EOF
}

if [[ $# -lt 2 ]]; then
  usage
  exit 2
fi

instance="$1"
command="$2"
shift 2

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
env_file="$repo_root/instances/${instance}.local.env"
example_env_file="$repo_root/instances/${instance}.env.example"
project="oxrm-${instance}"
image="${project}:local"
app_services=(scheduler worker web mcp api backup)
node_services=(api mcp web worker scheduler backup)

sanitize_instance_name() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/_/g; s/^_+//; s/_+$//'
}

generate_secret() {
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex 18
    return
  fi
  printf '%s-%s-%s' "$instance" "$RANDOM" "$(date +%s%N)" | sha256sum | awk '{print $1}'
}

port_in_use() {
  local port="$1"
  if command -v ss >/dev/null 2>&1; then
    ss -ltn | awk '{print $4}' | grep -Eq "[:.]${port}$"
    return
  fi
  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1
    return
  fi
  return 1
}

docker_daemon_ok() {
  command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1
}

pick_port_base() {
  local base
  for _ in $(seq 1 100); do
    base=$((20000 + RANDOM % 35000))
    if ! port_in_use "$base" &&
      ! port_in_use "$((base + 1))" &&
      ! port_in_use "$((base + 2))"; then
      printf '%s' "$base"
      return
    fi
  done
  echo "Could not find three free host ports for $instance" >&2
  exit 1
}

pick_port_triplet() {
  local base
  base="$(pick_port_base)"
  printf '%s %s %s\n' "$base" "$((base + 1))" "$((base + 2))"
}

set_env_value() {
  local file="$1"
  local key="$2"
  local value="$3"
  if grep -qE "^${key}=" "$file"; then
    sed -i -E "s|^${key}=.*|${key}=${value}|" "$file"
  else
    printf '%s=%s\n' "$key" "$value" >>"$file"
  fi
}

update_runtime_urls() {
  set_env_value "$env_file" OXRM_API_URL "http://127.0.0.1:${HOST_API_PORT}"
  set_env_value "$env_file" OXRM_MCP_URL "http://127.0.0.1:${HOST_MCP_PORT}/mcp"
  set_env_value "$env_file" CRM_API_URL "http://127.0.0.1:${HOST_API_PORT}"
  set_env_value "$env_file" CRM_MCP_URL "http://127.0.0.1:${HOST_MCP_PORT}/mcp"
}

write_public_ports() {
  set_env_value "$env_file" HOST_WEB_PORT "$HOST_WEB_PORT"
  set_env_value "$env_file" HOST_API_PORT "$HOST_API_PORT"
  set_env_value "$env_file" HOST_MCP_PORT "$HOST_MCP_PORT"
  update_runtime_urls
}

render_local_env() {
  local source_file="$1"
  local random_ports="$2"
  local safe_instance
  local db_name
  local db_user
  local password
  local web_port
  local api_port
  local mcp_port
  local postgres_port
  local redis_port

  safe_instance="$(sanitize_instance_name "$instance")"
  if [[ -z "$safe_instance" ]]; then
    echo "Invalid instance name: $instance" >&2
    exit 2
  fi

  cp "$source_file" "$env_file"

  db_name="oxrm_${safe_instance}"
  db_user="oxrm_${safe_instance}"
  password="$(generate_secret)"

  if [[ "$random_ports" == true ]]; then
    web_port="$(pick_port_base)"
    api_port="$((web_port + 1))"
    mcp_port="$((web_port + 2))"
  else
    web_port="${HOST_WEB_PORT:-$(grep -E '^HOST_WEB_PORT=' "$env_file" | cut -d= -f2-)}"
    api_port="${HOST_API_PORT:-$(grep -E '^HOST_API_PORT=' "$env_file" | cut -d= -f2-)}"
    mcp_port="${HOST_MCP_PORT:-$(grep -E '^HOST_MCP_PORT=' "$env_file" | cut -d= -f2-)}"
  fi

  set_env_value "$env_file" POSTGRES_DB "$db_name"
  set_env_value "$env_file" POSTGRES_USER "$db_user"
  set_env_value "$env_file" POSTGRES_PASSWORD "$password"
  set_env_value "$env_file" HOST_WEB_PORT "$web_port"
  set_env_value "$env_file" HOST_API_PORT "$api_port"
  set_env_value "$env_file" HOST_MCP_PORT "$mcp_port"
  sed -i -E '/^HOST_POSTGRES_PORT=/d; /^HOST_REDIS_PORT=/d' "$env_file"
  HOST_WEB_PORT="$web_port"
  HOST_API_PORT="$api_port"
  HOST_MCP_PORT="$mcp_port"
  update_runtime_urls
  set_env_value "$env_file" BACKUP_GITHUB_REPO ""
  set_env_value "$env_file" BACKUP_GITHUB_TOKEN ""
  set_env_value "$env_file" BACKUP_WORKSPACE ".backups/${instance}"
}

if [[ "$command" == "init" ]]; then
  if [[ -f "$env_file" ]]; then
    echo "$env_file already exists."
    exit 0
  fi
  random_ports=false
  if [[ "${OXRM_INIT_PORTS:-}" == "auto" ]]; then
    random_ports=true
  fi
  if [[ -f "$example_env_file" ]]; then
    render_local_env "$example_env_file" "$random_ports"
  elif [[ -f "$repo_root/instances/demo.env.example" ]]; then
    render_local_env "$repo_root/instances/demo.env.example" true
  else
    echo "Missing instances/demo.env.example; cannot initialize $instance." >&2
    exit 2
  fi
  echo "Created $env_file with local credentials and ports."
  exit 0
fi

if [[ ! -f "$env_file" ]]; then
  if [[ -f "$example_env_file" ]]; then
    echo "Missing $env_file. Copy $example_env_file and fill secrets." >&2
  else
    echo "Unknown instance: $instance" >&2
  fi
  exit 2
fi

cd "$repo_root"
set -a
# shellcheck source=/dev/null
source "$env_file"
set +a

if [[ "${NODE_ENV:-development}" == "production" ]]; then
  if [[ -z "${POSTGRES_PASSWORD:-}" || "${POSTGRES_PASSWORD:-}" == "change-me" || "${POSTGRES_PASSWORD:-}" == "oxrm" ]]; then
    echo "Refusing to run production instance $instance with a placeholder POSTGRES_PASSWORD." >&2
    exit 2
  fi
fi

compose() {
  docker compose --env-file "$env_file" -p "$project" "$@"
}

build_node_image() {
  local tag="$1"
  if docker build -t "$tag" -f infra/docker/node.Dockerfile .; then
    return
  fi
  echo "Docker build failed; retrying with host networking for Docker registry DNS." >&2
  docker build --network host -t "$tag" -f infra/docker/node.Dockerfile .
}

compose_service_image() {
  printf '%s-%s:latest' "$project" "$1"
}

compose_build_node_images() {
  if compose build; then
    return
  fi

  echo "Compose build failed; retrying one app image build with host networking for Docker registry DNS." >&2
  local base_service="${node_services[0]}"
  local base_image
  base_image="$(compose_service_image "$base_service")"
  docker build --network host -t "$base_image" -f infra/docker/node.Dockerfile .

  local service
  for service in "${node_services[@]:1}"; do
    docker tag "$base_image" "$(compose_service_image "$service")"
  done
}

has_compose() {
  docker compose version >/dev/null 2>&1
}

container_name() {
  printf '%s-%s' "$project" "$1"
}

internal_database_url() {
  printf 'postgres://%s:%s@postgres:5432/%s' "$POSTGRES_USER" "$POSTGRES_PASSWORD" "$POSTGRES_DB"
}

ensure_network() {
  docker network inspect "$project" >/dev/null 2>&1 || docker network create "$project" >/dev/null
}

remove_container() {
  docker rm -f "$(container_name "$1")" >/dev/null 2>&1 || true
}

wait_for_postgres() {
  local postgres
  postgres="$(container_name postgres)"
  for _ in $(seq 1 60); do
    if docker exec "$postgres" pg_isready -U "$POSTGRES_USER" -d "$POSTGRES_DB" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  echo "Postgres did not become ready for $instance" >&2
  return 1
}

direct_run_node_service() {
  local service="$1"
  local command="$2"
  local port_args=()
  shift 2

  case "$service" in
    api)
      port_args=(-p "127.0.0.1:${HOST_API_PORT}:18181")
      ;;
    mcp)
      port_args=(-p "127.0.0.1:${HOST_MCP_PORT}:18182")
      ;;
    web)
      port_args=(-p "127.0.0.1:${HOST_WEB_PORT}:18180")
      ;;
  esac

  remove_container "$service"
  docker run -d \
    --name "$(container_name "$service")" \
    --network "$project" \
    --network-alias "$service" \
    "${port_args[@]}" \
    -e NODE_ENV=development \
    -e LOG_LEVEL="${LOG_LEVEL:-info}" \
    -e OXRM_BACKUP_REQUIRED="${OXRM_BACKUP_REQUIRED:-false}" \
    -e OXRM_DEPLOY_TARGET="${OXRM_DEPLOY_TARGET:-local}" \
    -e OXRM_DEPLOY_VERSION="${OXRM_DEPLOY_VERSION:-0.2.1}" \
    -e OXRM_DEPLOY_GIT_SHA="${OXRM_DEPLOY_GIT_SHA:-}" \
    -e OXRM_DEPLOY_GIT_REF="${OXRM_DEPLOY_GIT_REF:-}" \
    -e OXRM_DEPLOY_GITHUB_RUN_ID="${OXRM_DEPLOY_GITHUB_RUN_ID:-}" \
    -e OXRM_DEPLOY_GITHUB_RUN_NUMBER="${OXRM_DEPLOY_GITHUB_RUN_NUMBER:-}" \
    -e OXRM_DEPLOYED_AT="${OXRM_DEPLOYED_AT:-}" \
    -e DATABASE_URL="$(internal_database_url)" \
    -e REDIS_URL=redis://redis:6379 \
    -e API_HOST=0.0.0.0 \
    -e API_PORT=18181 \
    -e MCP_HOST=0.0.0.0 \
    -e MCP_PORT=18182 \
    -e WEB_PORT=18180 \
    -e OXRM_API_PROXY_TARGET=http://api:18181 \
    -e CRM_API_PROXY_TARGET=http://api:18181 \
    "$image" \
    bash -lc "$command" >/dev/null
}

direct_up() {
  ensure_network
  build_node_image "$image"

  remove_container postgres
  docker run -d \
    --name "$(container_name postgres)" \
    --network "$project" \
    --network-alias postgres \
    -v "${project}-postgres-data:/var/lib/postgresql/data" \
    -e POSTGRES_DB="$POSTGRES_DB" \
    -e POSTGRES_USER="$POSTGRES_USER" \
    -e POSTGRES_PASSWORD="$POSTGRES_PASSWORD" \
    postgres:17 >/dev/null

  remove_container redis
  docker run -d \
    --name "$(container_name redis)" \
    --network "$project" \
    --network-alias redis \
    redis:8 >/dev/null

  wait_for_postgres
  direct_run_node_service api "scripts/oxrm-internal run api"
  direct_run_node_service mcp "scripts/oxrm-internal run mcp"
  direct_run_node_service web "scripts/oxrm-internal dev web-container"
  direct_run_node_service worker "scripts/oxrm-internal run worker"
  direct_run_node_service scheduler "scripts/oxrm-internal run scheduler"
}

direct_down() {
  for service in scheduler worker web mcp api redis postgres; do
    remove_container "$service"
  done
}

direct_reset() {
  direct_down
  docker volume rm "${project}-postgres-data" >/dev/null 2>&1 || true
  docker network rm "$project" >/dev/null 2>&1 || true
}

direct_exec_node() {
  docker run --rm \
    --network "$project" \
    -e NODE_ENV=development \
    -e DATABASE_URL="$(internal_database_url)" \
    -e REDIS_URL=redis://redis:6379 \
    "$image" \
    "$@"
}

backup_workspace_host_path() {
  if [[ "${BACKUP_WORKSPACE:-}" = /* ]]; then
    printf '%s' "$BACKUP_WORKSPACE"
  else
    printf '%s/%s' "$repo_root" "${BACKUP_WORKSPACE:-.backups/${instance}}"
  fi
}

direct_cli() {
  docker run --rm \
    --network "$project" \
    -e CRM_API_URL=http://api:18181 \
    -e OXRM_API_URL=http://api:18181 \
    -e CRM_MCP_URL=http://mcp:18182/mcp \
    -e OXRM_MCP_URL=http://mcp:18182/mcp \
    "$image" \
    scripts/oxrm-internal cli "$@"
}

direct_backup() {
  local backup_workspace
  backup_workspace="$(backup_workspace_host_path)"
  mkdir -p "$backup_workspace"
  docker run --rm \
    --network "$project" \
    -v "${backup_workspace}:/backup-workspace" \
    -e NODE_ENV="${NODE_ENV:-development}" \
    -e DATABASE_URL="$(internal_database_url)" \
    -e BACKUP_GITHUB_REPO="${BACKUP_GITHUB_REPO:-}" \
    -e BACKUP_GITHUB_TOKEN="${BACKUP_GITHUB_TOKEN:-}" \
    -e BACKUP_GIT_AUTHOR_NAME="${BACKUP_GIT_AUTHOR_NAME:-oXRM Backup}" \
    -e BACKUP_GIT_AUTHOR_EMAIL="${BACKUP_GIT_AUTHOR_EMAIL:-backups@oxrm.local}" \
    -e BACKUP_WORKSPACE=/backup-workspace \
    "$image" \
    scripts/oxrm-internal backup dev
}

direct_verify() {
  local backup_workspace
  backup_workspace="$(backup_workspace_host_path)"
  mkdir -p "$backup_workspace"
  docker run --rm \
    --network "$project" \
    -v "${backup_workspace}:/backup-workspace" \
    -e NODE_ENV="${NODE_ENV:-development}" \
    -e DATABASE_URL="$(internal_database_url)" \
    -e BACKUP_GITHUB_REPO="${BACKUP_GITHUB_REPO:-}" \
    -e BACKUP_GITHUB_TOKEN="${BACKUP_GITHUB_TOKEN:-}" \
    -e BACKUP_WORKSPACE=/backup-workspace \
    "$image" \
    scripts/oxrm-internal backup verify-source
}

compose_backup() {
  local backup_workspace
  backup_workspace="$(backup_workspace_host_path)"
  mkdir -p "$backup_workspace"
  compose run --rm \
    -v "${backup_workspace}:/backup-workspace" \
    -e BACKUP_WORKSPACE=/backup-workspace \
    backup scripts/oxrm-internal backup dev
}

compose_verify() {
  local backup_workspace
  backup_workspace="$(backup_workspace_host_path)"
  mkdir -p "$backup_workspace"
  compose run --rm \
    -v "${backup_workspace}:/backup-workspace" \
    -e BACKUP_WORKSPACE=/backup-workspace \
    backup scripts/oxrm-internal backup verify-source
}

compose_run_node() {
  compose run --rm --no-deps api "$@"
}

compose_stop_app_services() {
  compose stop "${app_services[@]}" >/dev/null || true
}

compose_start_app_services() {
  compose up -d "${node_services[@]}"
}

compose_cli() {
  compose exec -T \
    -e OXRM_API_URL=http://api:18181 \
    -e CRM_API_URL=http://api:18181 \
    -e OXRM_MCP_URL=http://mcp:18182/mcp \
    -e CRM_MCP_URL=http://mcp:18182/mcp \
    api scripts/oxrm-internal cli "$@"
}

compose_wait_for_app() {
  for _ in $(seq 1 60); do
    if compose_cli health >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  echo "API/MCP did not become ready for $instance" >&2
  compose ps >&2 || true
  return 1
}

direct_stop_app_services() {
  for service in "${app_services[@]}"; do
    remove_container "$service"
  done
}

direct_start_app_services() {
  direct_run_node_service api "scripts/oxrm-internal run api"
  direct_run_node_service mcp "scripts/oxrm-internal run mcp"
  direct_run_node_service web "scripts/oxrm-internal dev web-container"
  direct_run_node_service worker "scripts/oxrm-internal run worker"
  direct_run_node_service scheduler "scripts/oxrm-internal run scheduler"
}

direct_wait_for_app() {
  for _ in $(seq 1 60); do
    if direct_cli health >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  echo "API/MCP did not become ready for $instance" >&2
  docker ps -a --filter "name=${project}-" --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}' >&2 || true
  return 1
}

project_owns_port() {
  local port="$1"
  docker ps --filter "name=${project}-" --format '{{.Ports}}' 2>/dev/null | grep -Eq "(127\\.0\\.0\\.1|0\\.0\\.0\\.0|:::):${port}->"
}

print_port_owner() {
  local port="$1"
  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -iTCP:"$port" -sTCP:LISTEN 2>/dev/null | sed -n '2p' | awk '{$1=$1; print}'
    return
  fi
  if command -v ss >/dev/null 2>&1; then
    ss -ltnp 2>/dev/null | awk -v port="$port" '$4 ~ ":" port "$" {print $0; exit}'
  fi
}

preflight_public_ports() {
  local failures=0
  local entries=(
    "Web:${HOST_WEB_PORT}"
    "API:${HOST_API_PORT}"
    "MCP:${HOST_MCP_PORT}"
  )
  for entry in "${entries[@]}"; do
    local label="${entry%%:*}"
    local port="${entry#*:}"
    if port_in_use "$port" && ! project_owns_port "$port"; then
      echo "${label} port ${port} is already in use." >&2
      print_port_owner "$port" >&2 || true
      failures=$((failures + 1))
    fi
  done
  if [[ "$failures" -gt 0 ]]; then
    echo "" >&2
    echo "Repair with: ./oxrm -i ${instance} ports repair" >&2
    echo "Or run the full repair flow: ./oxrm -i ${instance} repair" >&2
    echo "Inspect ports with: ./oxrm -i ${instance} doctor" >&2
    exit 1
  fi
}

public_port_conflict_count() {
  local failures=0
  local entries=(
    "Web:${HOST_WEB_PORT}"
    "API:${HOST_API_PORT}"
    "MCP:${HOST_MCP_PORT}"
  )
  for entry in "${entries[@]}"; do
    local port="${entry#*:}"
    if port_in_use "$port" && ! project_owns_port "$port"; then
      failures=$((failures + 1))
    fi
  done
  printf '%s' "$failures"
}

repair_public_ports() {
  local force=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force)
        force=true
        ;;
      *)
        echo "Unknown ports repair option: $1" >&2
        exit 2
        ;;
    esac
    shift
  done

  local conflicts
  conflicts="$(public_port_conflict_count)"
  if [[ "$conflicts" == "0" && "$force" == false ]]; then
    echo "No port repair needed for instance '${instance}'."
    print_urls
    return
  fi

  local old_web="$HOST_WEB_PORT"
  local old_api="$HOST_API_PORT"
  local old_mcp="$HOST_MCP_PORT"
  read -r HOST_WEB_PORT HOST_API_PORT HOST_MCP_PORT <<<"$(pick_port_triplet)"
  write_public_ports

  echo "Reassigned public ports for '${instance}':"
  echo "  Web: ${old_web} -> ${HOST_WEB_PORT}"
  echo "  API: ${old_api} -> ${HOST_API_PORT}"
  echo "  MCP: ${old_mcp} -> ${HOST_MCP_PORT}"
  echo ""
  print_urls
}

clean_orphans() {
  if has_compose; then
    compose down --remove-orphans >/dev/null 2>&1 || true
  else
    docker ps -a --filter "name=${project}-" --filter "status=exited" -q 2>/dev/null | xargs -r docker rm >/dev/null 2>&1 || true
  fi
}

required_env_keys() {
  cat <<'EOF'
POSTGRES_DB
POSTGRES_USER
POSTGRES_PASSWORD
HOST_WEB_PORT
HOST_API_PORT
HOST_MCP_PORT
EOF
}

repair_env_defaults() {
  local changed=false
  if [[ -z "${OXRM_API_URL:-}" ]]; then
    set_env_value "$env_file" OXRM_API_URL "http://127.0.0.1:${HOST_API_PORT}"
    OXRM_API_URL="http://127.0.0.1:${HOST_API_PORT}"
    changed=true
  fi
  if [[ -z "${OXRM_MCP_URL:-}" ]]; then
    set_env_value "$env_file" OXRM_MCP_URL "http://127.0.0.1:${HOST_MCP_PORT}/mcp"
    OXRM_MCP_URL="http://127.0.0.1:${HOST_MCP_PORT}/mcp"
    changed=true
  fi
  if [[ -z "${CRM_API_URL:-}" ]]; then
    set_env_value "$env_file" CRM_API_URL "${OXRM_API_URL}"
    CRM_API_URL="$OXRM_API_URL"
    changed=true
  fi
  if [[ -z "${CRM_MCP_URL:-}" ]]; then
    set_env_value "$env_file" CRM_MCP_URL "${OXRM_MCP_URL}"
    CRM_MCP_URL="$OXRM_MCP_URL"
    changed=true
  fi
  if [[ -z "${BACKUP_WORKSPACE:-}" ]]; then
    set_env_value "$env_file" BACKUP_WORKSPACE ".backups/${instance}"
    BACKUP_WORKSPACE=".backups/${instance}"
    changed=true
  fi
  if [[ "$changed" == true ]]; then
    echo "Backfilled missing local env defaults in ${env_file}."
  fi
}

validate_instance_env() {
  local failures=0
  local key
  while read -r key; do
    if [[ -z "${!key:-}" ]]; then
      echo "  ${key}: missing"
      failures=$((failures + 1))
    else
      echo "  ${key}: set"
    fi
  done < <(required_env_keys)

  if [[ -z "${OXRM_API_URL:-}" && -n "${CRM_API_URL:-}" ]]; then
    echo "  OXRM_API_URL: missing, legacy CRM_API_URL fallback is set"
  elif [[ -z "${OXRM_API_URL:-}" ]]; then
    echo "  OXRM_API_URL: missing, repair will backfill from HOST_API_PORT"
  else
    echo "  OXRM_API_URL: set"
  fi

  if [[ -z "${OXRM_MCP_URL:-}" && -n "${CRM_MCP_URL:-}" ]]; then
    echo "  OXRM_MCP_URL: missing, legacy CRM_MCP_URL fallback is set"
  elif [[ -z "${OXRM_MCP_URL:-}" ]]; then
    echo "  OXRM_MCP_URL: missing, repair will backfill from HOST_MCP_PORT"
  else
    echo "  OXRM_MCP_URL: set"
  fi

  if [[ "${POSTGRES_PASSWORD:-}" == "change-me" || "${POSTGRES_PASSWORD:-}" == "oxrm" || -z "${POSTGRES_PASSWORD:-}" ]]; then
    if [[ "${NODE_ENV:-development}" == "production" ]]; then
      echo "  POSTGRES_PASSWORD: weak or placeholder"
      failures=$((failures + 1))
    else
      echo "  POSTGRES_PASSWORD: weak development password; safe only for disposable local data"
    fi
  fi

  return "$failures"
}

print_disk_status() {
  if command -v df >/dev/null 2>&1; then
    df -Pk "$repo_root" | awk 'NR == 2 { printf "Disk: %s KB available at %s\n", $4, $6 }'
  else
    echo "Disk: df not available"
  fi
}

compose_running() {
  local services
  services="$(compose ps --services --status running 2>/dev/null || true)"
  grep -qx api <<<"$services" &&
    grep -qx mcp <<<"$services" &&
    grep -qx web <<<"$services"
}

direct_running() {
  docker inspect "$(container_name api)" "$(container_name mcp)" "$(container_name web)" >/dev/null 2>&1 || return 1
  [[ "$(docker inspect -f '{{.State.Running}}' "$(container_name api)" 2>/dev/null)" == true ]] &&
    [[ "$(docker inspect -f '{{.State.Running}}' "$(container_name mcp)" 2>/dev/null)" == true ]] &&
    [[ "$(docker inspect -f '{{.State.Running}}' "$(container_name web)" 2>/dev/null)" == true ]]
}

print_urls() {
  printf 'Web: %s\n' "http://127.0.0.1:${HOST_WEB_PORT}"
  printf 'API health: %s\n' "http://127.0.0.1:${HOST_API_PORT}/api/health"
  printf 'MCP health: %s\n' "http://127.0.0.1:${HOST_MCP_PORT}/health"
  printf 'MCP endpoint: %s\n' "http://127.0.0.1:${HOST_MCP_PORT}/mcp"
  if [[ "${HOST_MCP_PORT}" != "18182" ]]; then
    printf '\nAssistant MCP registration URL: %s\n' "http://127.0.0.1:${HOST_MCP_PORT}/mcp"
  fi
}

compose_up_idempotent() {
  if compose_running; then
    echo "oXRM instance '${instance}' is already running."
    print_urls
    return
  fi
  preflight_public_ports
  if ! compose_build_node_images || ! compose up -d; then
    echo "" >&2
    echo "Startup failed for instance '${instance}'." >&2
    echo "Stopping newly-started app containers while preserving volumes." >&2
    compose stop "${app_services[@]}" >/dev/null 2>&1 || true
    compose ps >&2 || true
    echo "" >&2
    echo "Recovery commands:" >&2
    echo "  ./oxrm -i ${instance} logs" >&2
    echo "  ./oxrm -i ${instance} restart" >&2
    exit 1
  fi
  print_urls
}

direct_up_idempotent() {
  if direct_running; then
    echo "oXRM instance '${instance}' is already running."
    print_urls
    return
  fi
  preflight_public_ports
  if ! direct_up; then
    echo "" >&2
    echo "Startup failed for instance '${instance}'." >&2
    echo "Stopping newly-started app containers while preserving volumes." >&2
    direct_stop_app_services
    docker ps -a --filter "name=${project}-" --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}' >&2 || true
    echo "" >&2
    echo "Recovery commands:" >&2
    echo "  ./oxrm -i ${instance} logs" >&2
    echo "  ./oxrm -i ${instance} restart" >&2
    exit 1
  fi
  print_urls
}

codex_doctor() {
  echo ""
  echo "Codex:"
  if ! command -v codex >/dev/null 2>&1; then
    echo "  Status: Not installed"
    echo "  Install Codex, then rerun: ./oxrm doctor --codex"
    return
  fi

  local codex_path
  codex_path="$(command -v codex)"
  if codex_version="$(codex --version 2>&1)"; then
    echo "  Status: Installed and working"
    echo "  Path: ${codex_path}"
    echo "  Version: ${codex_version}"
    return
  fi

  echo "  Status: Installed but broken"
  echo "  Path: ${codex_path}"
  echo "  Error: ${codex_version}"
  cat <<'EOF'
  Repair checklist:
    which -a codex
    npm uninstall -g @openai/codex codex
    hash -r
    install the current standalone Codex CLI
    codex --version
EOF
}

run_doctor() {
  local include_codex=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --codex)
        include_codex=true
        ;;
      *)
        echo "Unknown doctor option: $1" >&2
        exit 2
        ;;
    esac
    shift
  done

  echo "oXRM doctor"
  echo "Instance: ${instance}"
  echo "Project: ${project}"
  echo "Env: ${env_file}"
  echo ""
  if command -v docker >/dev/null 2>&1; then
    echo "Docker: $(docker --version)"
    if docker_daemon_ok; then
      echo "Docker daemon: running"
    else
      echo "Docker daemon: not reachable"
    fi
  else
    echo "Docker: not installed"
  fi
  if has_compose; then
    echo "Compose: $(docker compose version --short 2>/dev/null || docker compose version)"
  else
    echo "Compose: not installed; direct Docker fallback will be used"
  fi
  print_disk_status
  echo ""
  echo "Config:"
  if validate_instance_env; then
    echo "  Config status: ok"
  else
    echo "  Config status: needs attention"
  fi
  echo ""
  echo "Ports:"
  for entry in "Web:${HOST_WEB_PORT}" "API:${HOST_API_PORT}" "MCP:${HOST_MCP_PORT}"; do
    local label="${entry%%:*}"
    local port="${entry#*:}"
    if port_in_use "$port"; then
      if project_owns_port "$port"; then
        echo "  ${label} ${port}: in use by this oXRM instance"
      else
        echo "  ${label} ${port}: blocked by another process"
        print_port_owner "$port" | sed 's/^/    /' || true
      fi
    else
      echo "  ${label} ${port}: available"
    fi
  done
  if [[ "$(public_port_conflict_count)" != "0" ]]; then
    echo ""
    echo "Port repair:"
    echo "  ./oxrm -i ${instance} ports repair"
  fi
  echo ""
  echo "Repair:"
  echo "  ./oxrm -i ${instance} repair"
  echo ""
  print_urls
  if [[ "$include_codex" == true ]]; then
    codex_doctor
  fi
}

run_repair() {
  local skip_smoke=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --skip-smoke)
        skip_smoke=true
        ;;
      *)
        echo "Unknown repair option: $1" >&2
        exit 2
        ;;
    esac
    shift
  done

  echo "Repairing oXRM instance '${instance}'..."
  if ! docker_daemon_ok; then
    echo "Docker is not reachable. Start Docker and rerun: ./oxrm -i ${instance} repair" >&2
    exit 1
  fi

  if [[ "$(public_port_conflict_count)" != "0" ]]; then
    repair_public_ports
  fi

  repair_env_defaults

  clean_orphans

  if has_compose; then
    compose_up_idempotent
    compose exec -T api scripts/oxrm-internal db migrate
    compose exec -T api scripts/oxrm-internal db seed
    if [[ "$skip_smoke" == false ]]; then
      compose_wait_for_app
      compose_cli health
    fi
  else
    direct_up_idempotent
    direct_exec_node scripts/oxrm-internal db migrate
    direct_exec_node scripts/oxrm-internal db seed
    if [[ "$skip_smoke" == false ]]; then
      direct_wait_for_app
      direct_cli health
    fi
  fi

  echo ""
  echo "Repair complete."
  print_urls
}

parse_upgrade_flags() {
  upgrade_skip_backup=false
  upgrade_skip_smoke=false
  upgrade_skip_seed=false
  upgrade_skip_build=false
  upgrade_demo_scenario=none

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --skip-backup)
        upgrade_skip_backup=true
        ;;
      --skip-smoke)
        upgrade_skip_smoke=true
        ;;
      --skip-seed)
        upgrade_skip_seed=true
        ;;
      --skip-build)
        upgrade_skip_build=true
        ;;
      --demo)
        if [[ $# -lt 2 ]]; then
          echo "Missing scenario after --demo" >&2
          exit 2
        fi
        upgrade_demo_scenario="$2"
        shift
        ;;
      --demo=*)
        upgrade_demo_scenario="${1#*=}"
        ;;
      -h|--help)
        cat <<'EOF'
Usage: ./oxrm -i <instance> upgrade [--skip-backup] [--skip-smoke] [--skip-seed] [--skip-build] [--demo none|job-search|linkedin-outreach]

Default upgrade flow:
  1. Ensure data services are running.
  2. Run and verify a backup.
  3. Stop app/writer services while keeping Postgres and Redis running.
  4. Build the app image.
  5. Run migrations once.
  6. Run idempotent baseline seed.
  7. Optionally run one explicit demo scenario.
  8. Restart app services.
  9. Run health and smoke checks.

Use --skip-backup only for disposable local instances.
EOF
        exit 0
        ;;
      *)
        echo "Unknown upgrade flag: $1" >&2
        exit 2
        ;;
    esac
    shift
  done

  case "$upgrade_demo_scenario" in
    none|job-search|linkedin-outreach)
      ;;
    *)
      echo "Unknown demo scenario: $upgrade_demo_scenario" >&2
      echo "Use none, job-search, or linkedin-outreach." >&2
      exit 2
      ;;
  esac
}

compose_upgrade() {
  compose up -d postgres redis

  if [[ "$upgrade_skip_backup" == false ]]; then
    compose_backup
    compose_verify
  else
    echo "Skipping backup for $instance. Do not use --skip-backup for production upgrades." >&2
  fi

  compose_stop_app_services
  if [[ "$upgrade_skip_build" == false ]]; then
    compose_build_node_images
  fi
  compose_run_node scripts/oxrm-internal db migrate
  if [[ "$upgrade_skip_seed" == false ]]; then
    compose_run_node scripts/oxrm-internal db seed
  fi
  if [[ "$upgrade_demo_scenario" != none ]]; then
    compose_run_node scripts/oxrm-internal db demo "$upgrade_demo_scenario"
  fi
  compose_start_app_services

  if [[ "$upgrade_skip_smoke" == false ]]; then
    compose_wait_for_app
    compose_cli health
    compose_cli smoke
  fi
}

direct_upgrade() {
  ensure_network
  if ! docker image inspect "$image" >/dev/null 2>&1 && [[ "$upgrade_skip_build" == false ]]; then
    build_node_image "$image"
  fi

  if ! docker inspect "$(container_name postgres)" >/dev/null 2>&1 || ! docker inspect "$(container_name redis)" >/dev/null 2>&1; then
    direct_up
  fi
  wait_for_postgres

  if [[ "$upgrade_skip_backup" == false ]]; then
    direct_backup
    direct_verify
  else
    echo "Skipping backup for $instance. Do not use --skip-backup for production upgrades." >&2
  fi

  direct_stop_app_services
  if [[ "$upgrade_skip_build" == false ]]; then
    build_node_image "$image"
  fi
  direct_exec_node scripts/oxrm-internal db migrate
  if [[ "$upgrade_skip_seed" == false ]]; then
    direct_exec_node scripts/oxrm-internal db seed
  fi
  if [[ "$upgrade_demo_scenario" != none ]]; then
    direct_exec_node scripts/oxrm-internal db demo "$upgrade_demo_scenario"
  fi
  direct_start_app_services

  if [[ "$upgrade_skip_smoke" == false ]]; then
    direct_wait_for_app
    direct_cli health
    direct_cli smoke
  fi
}

case "$command" in
  config)
    if has_compose; then
      compose config
    else
      echo "Docker Compose is not installed; this instance runner will use direct Docker containers."
    fi
    ;;
  up)
    if has_compose; then
      compose_up_idempotent
    else
      direct_up_idempotent
    fi
    ;;
  down)
    if has_compose; then
      compose down
    else
      direct_down
    fi
    ;;
  reset)
    if has_compose; then
      compose down -v --remove-orphans
      direct_reset
    else
      direct_reset
    fi
    ;;
  ps)
    if has_compose; then
      compose ps
    else
      docker ps -a --filter "name=${project}-" --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'
    fi
    ;;
  doctor)
    run_doctor "$@"
    ;;
  ports)
    print_urls
    ;;
  ports-repair)
    repair_public_ports "$@"
    ;;
  repair)
    run_repair "$@"
    ;;
  logs)
    if has_compose; then
      compose logs -f "$@"
    else
      if [[ $# -eq 0 ]]; then
        docker logs -f "$(container_name api)"
      else
        docker logs -f "$(container_name "$1")"
      fi
    fi
    ;;
  cli)
    if has_compose; then
      compose exec -T \
        -e OXRM_API_URL=http://api:18181 \
        -e CRM_API_URL=http://api:18181 \
        -e OXRM_MCP_URL=http://mcp:18182/mcp \
        -e CRM_MCP_URL=http://mcp:18182/mcp \
        api scripts/oxrm-internal cli "$@"
    else
      direct_cli "$@"
    fi
    ;;
  migrate)
    if has_compose; then
      compose exec -T api scripts/oxrm-internal db migrate
    else
      direct_exec_node scripts/oxrm-internal db migrate
    fi
    ;;
  seed)
    if has_compose; then
      compose exec -T api scripts/oxrm-internal db seed
    else
      direct_exec_node scripts/oxrm-internal db seed
    fi
    ;;
  demo-seed)
    if has_compose; then
      compose exec -T api scripts/oxrm-internal db demo "$@"
    else
      direct_exec_node scripts/oxrm-internal db demo "$@"
    fi
    ;;
  db-smoke)
    if has_compose; then
      compose exec -T api scripts/oxrm-internal db smoke
    else
      direct_exec_node scripts/oxrm-internal db smoke
    fi
    ;;
  health)
    if has_compose; then
      compose exec -T \
        -e OXRM_API_URL=http://api:18181 \
        -e CRM_API_URL=http://api:18181 \
        -e OXRM_MCP_URL=http://mcp:18182/mcp \
        -e CRM_MCP_URL=http://mcp:18182/mcp \
        api scripts/oxrm-internal cli health
    else
      direct_cli health
    fi
    ;;
  smoke)
    if has_compose; then
      compose exec -T \
        -e CRM_API_URL=http://api:18181 \
        -e CRM_MCP_URL=http://mcp:18182/mcp \
        api scripts/oxrm-internal cli smoke
    else
      direct_cli smoke
    fi
    ;;
  backup)
    if has_compose; then
      compose_backup
    else
      direct_backup
    fi
    ;;
  verify)
    if has_compose; then
      compose_verify
    else
      direct_verify
    fi
    ;;
  upgrade)
    parse_upgrade_flags "$@"
    if has_compose; then
      compose_upgrade
    else
      direct_upgrade
    fi
    ;;
  urls)
    print_urls
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac
