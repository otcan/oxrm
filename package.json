{
  "name": "orkestr-crm",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm typecheck",
    "typecheck": "pnpm -r typecheck",
    "dev:api": "pnpm --filter @orkestr-crm/api dev",
    "dev:mcp": "pnpm --filter @orkestr-crm/mcp dev",
    "dev:web": "pnpm --filter @orkestr-crm/web start",
    "crm": "pnpm --filter @orkestr-crm/cli start",
    "smoke": "pnpm --filter @orkestr-crm/cli smoke",
    "db:generate": "pnpm --filter @orkestr-crm/db db:generate",
    "db:migrate": "pnpm --filter @orkestr-crm/db db:migrate",
    "db:seed": "pnpm --filter @orkestr-crm/db db:seed",
    "db:smoke": "pnpm --filter @orkestr-crm/db db:smoke",
    "compose:config": "docker compose config",
    "backup:run": "pnpm --filter @orkestr-crm/backup start",
    "backup:verify": "pnpm --filter @orkestr-crm/backup verify"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
