{
  "name": "oxrm",
  "version": "0.2.1",
  "description": "Self-hosted outreach workspace for job search, customer outreach, partnerships, and follow-ups.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/otcan/oxrm.git"
  },
  "homepage": "https://github.com/otcan/oxrm#readme",
  "bugs": {
    "url": "https://github.com/otcan/oxrm/issues"
  },
  "keywords": [
