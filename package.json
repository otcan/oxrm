    "job-search",
    "crm",
    "xrm",
    "agents",
    "mcp",
    "docker",
    "local-first",
    "sales",
    "founder-tools"
  ],
  "packageManager": "pnpm@11.6.0",
  "type": "module",
  "scripts": {
